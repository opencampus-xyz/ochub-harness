{
  "name": "@opencampus/ochub-harness",
  "version": "0.0.1",
  "description": "Test harness for OCID-authenticated mini apps",
  "type": "module",
  "bin": {
    "ochub-harness": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:app && npm run build:cli",
    "build:app": "vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "dev": "vite",
    "format": "prettier -w .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "express": "^4.21.2",
    "express-http-proxy": "^2.1.2"
  },
  "devDependencies": {
    "@opencampus/ocid-connect-js": "^1.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/express": "^5.0.0",
    "@types/express-http-proxy": "^1.6.7",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "keywords": [
    "opencampus",
    "ocid",
    "mini-app",
    "test-harness"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencampus/ochub-harness.git"
  },
  "author": "Open Campus",
  "homepage": "https://github.com/opencampus/ochub-harness#readme",
  "bugs": {
    "url": "https://github.com/opencampus/ochub-harness/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
